rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data) 
        && request.resource.data.uid == resource.data.uid // UID is immutable
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'email'])
        );

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'status']) 
          && data.keys().size() <= 6
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() < 150
          && data.status in ['free', 'pro', 'single_paid']
          && (data.updatedAt == request.time || data.updatedAt == null);
      }
    }

    // --- Resumes Collection ---
    match /resumes/{resumeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid 
        && isValidResume(request.resource.data);
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId // userId is immutable
        && isValidResume(request.resource.data)
        && (
          // Action: Edit Content
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'templateId', 'personalInfo', 'experience', 'education', 
            'skills', 'languages', 'projects', 'interests', 'updatedAt', 'id', 'userId', 'isPaid', 'hdDownloaded'
          ])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidResume(data) {
        return data.keys().hasAll(['id', 'userId', 'updatedAt'])
          && data.userId == request.auth.uid
          && data.id is string && data.id.size() <= 128
          && (data.updatedAt == request.time || data.updatedAt == null); 
      }
    }
  }
}
